# App
NODE_ENV="development"
APP_BASE_URL="http://localhost:3000"
TIMEZONE="America/Montevideo"
NEXT_DIST_DIR=""

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Auth.js
AUTH_SECRET="change-me"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_BOOTSTRAP_EMAIL=""
AUTH_BOOTSTRAP_PASSWORD=""
NEXTAUTH_URL=""
NEXT_PUBLIC_APP_URL=""
VERCEL_PROD_APP_BASE_URL=""

# Cron
CRON_SECRET=""

# Zoom OAuth / API
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
ZOOM_GROUP_ID=""
ZOOM_WEBHOOK_SECRET_TOKEN=""
PASSWORD_WEBHOOK_URL=""
ZOOM_API_BASE="https://api.zoom.us/v2"

# Zoom rooms defaults
ZOOM_ROOMS_DEFAULT_ENABLED="false"
ZOOM_ROOMS_GROUP_NAME="Todo FLACSO"
ZOOM_ROOMS_GROUP_ALIASES="Todo FLACSO"
ZOOM_ROOMS_EXCLUDED_ACCOUNTS="web@flacso.edu.uy"
ZOOM_ROOMS_FIND_EXISTING="true"
ZOOM_ROOMS_MAX_PER_RUN="25"
ZOOM_ROOMS_TIMEZONE="America/Montevideo"
ZOOM_ROOMS_REMINDER_OFFSETS_HOURS="24"
ZOOM_ROOMS_REMINDER_LOOKBACK_MINUTES="90"

# Google service account / Drive / Gmail
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_SERVICE_ACCOUNT_SUBJECT=""
DRIVE_DESTINATION_ID=""
MONTHLY_ACCOUNTING_DRIVE_FOLDER_ID=""

# SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@flacso.edu.uy"
SMTP_SECURE="false"

# Push notifications
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@flacso.edu.uy"

# Integration tests
RUN_GOOGLE_INTEGRATION_TESTS="0"
